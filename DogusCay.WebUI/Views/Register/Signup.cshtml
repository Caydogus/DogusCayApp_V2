@model UserRegisterDto
@{
	Layout = null;
}

<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8">
	<title>Doguş Çay Kullanıcı Kayıt Ekranı </title>
	<meta name="viewport" content="width=device-width, initial-scale=1.0">

	<!-- LINEARICONS -->
	<link rel="stylesheet" href="~/colorlib-regform-26/fonts/linearicons/style.css">

	<!-- STYLE CSS -->
	<link rel="stylesheet" href="~/colorlib-regform-26/css/style.css">
</head>

<body>

	<div class="wrapper">
		<div class="inner">
			<img src="~/colorlib-regform-26/images/image-1.png" alt="" class="image-1">
			<form asp-action="Signup" asp-controller="Register" method="post">
				<h3>Yeni Hesap</h3>
				<div class="form-holder">
					<span class="lnr lnr-user"></span>
					<input type="text" asp-for="FirstName" class="form-control" placeholder="Adınız">
				</div>
				<div class="form-holder">
					<span class="lnr lnr-user"></span>
					<input type="text" asp-for="LastName" class="form-control" placeholder="Soyadınız">
				</div>
				<div class="form-holder">
					<span class="lnr lnr-user"></span>
					<input type="text" asp-for="UserName" class="form-control" placeholder="Kullanıcı Adı">
				</div>
				<div class="form-holder">
					<span class="lnr lnr-envelope"></span>
					<input type="text" asp-for="Email" class="form-control" placeholder="Mail Adresi">
				</div>
				<div class="form-holder">
					<span class="lnr lnr-lock"></span>
					<input type="password" asp-for="Password" class="form-control" placeholder="Şifre">
				</div>
				<div class="form-holder">
					<span class="lnr lnr-lock"></span>
					<input type="password" asp-for="ConfirmPassword" class="form-control" placeholder="Şifre Tekrarı">
				</div>
				<button type="submit">
					<span>Kayıt Ol</span>
				</button>
				<br />
				<div class="text-center p-t-136">
					<a class="txt2" href="/Login/SignIn/">
						Bir Hesabım var
						<i class="fa fa-long-arrow-right m-l-5" aria-hidden="true"></i>
					</a>
				</div>
			</form>
			<img src="~/colorlib-regform-26/images/image-2.png" alt="" class="image-2">
		</div>

	</div>

	<script src="~/colorlib-regform-26/js/jquery-3.3.1.min.js"></script>
	<script src="~/colorlib-regform-26/js/main.js"></script>
</body><!-- This templates was made by Colorlib (https://colorlib.com) -->
</html>