	<!-- Yukarı Çık Butonu (sağ altta) -->
	<button id="toTopBtn"
			style="display:none; position:fixed; right:24px; bottom:24px; z-index:9999; border-radius:50%; width:48px; height:48px; background:#495057; color:#fff; font-size:28px; border:none; box-shadow:0 2px 8px #0003; cursor:pointer;"
			aria-label="Yukarı Çık">
		<i class="bi bi-arrow-up"></i>
	</button>
	<script>
		$(window).scroll(function () {
			if ($(this).scrollTop() > 200) {
				$('#toTopBtn').fadeIn();
			} else {
				$('#toTopBtn').fadeOut();
			}
		});

		$('#toTopBtn').click(function () {
			$('html, body').animate({ scrollTop: 0 }, 500);
			return false;
		});
	</script>
