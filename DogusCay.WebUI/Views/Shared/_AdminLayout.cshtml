<script>
	$(document).ready(function () {
		$('#mainSearchInput').on('input', function () {
			let searchText = $(this).val().toLocaleLowerCase('tr');

			// Masaüstü tablosunda arama (her zaman uygula)
			$('.searchable-table tbody tr').each(function () {
				let found = false;
				$(this).find('td').each(function () {
					if ($(this).text().toLocaleLowerCase('tr').indexOf(searchText) !== -1) {
						found = true;
						return false;
					}
				});
				$(this).toggle(found);
			});

			// Mobil kartlarda arama (her zaman uygula)
			$('.searchable-list .mal-yukleme-card').each(function () {
				let cardText = $(this).text().toLocaleLowerCase('tr');
				$(this).toggle(cardText.indexOf(searchText) !== -1);
			});
		});
	});
</script>

<script>
	$(function () {
		// Sayfa yüklenince sidebar'ı mini başlat
		$("#main-wrapper").attr("data-sidebartype", "mini-sidebar").addClass("mini-sidebar");
		$("body").addClass("mini-sidebar");

		// Hover ile aç/kapat davranışı
		$(".left-sidebar").hover(
			function () {
				$("#main-wrapper").removeClass("mini-sidebar");
				$("body").removeClass("mini-sidebar");
				$("#main-wrapper").attr("data-sidebartype", "full");
			},
			function () {
				$("#main-wrapper").addClass("mini-sidebar");
				$("body").addClass("mini-sidebar");
				$("#main-wrapper").attr("data-sidebartype", "mini-sidebar");
			}
		);
	});
</script>
