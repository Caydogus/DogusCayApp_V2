@model UpdateKanalDto
@{
    ViewData["Title"] = "UpdateKanal";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<section class="content container-fluid">
    <div class="row">

        <div class="col-md-12">
            <div class="chart-box">
                <h4>Kanal Güncelleme Sayfası</h4>
                <br />
                <div class="bs-example" data-example-id="bordered-table">

                    <form method="post">
                        <input type="hidden" asp-for="KanalId" />
                        <label>Kategori Adı</label>
                        <input type="text" class="form-control" asp-for="KanalName" />
                        <br />
                        <button class="btn btn-primary">Kanal Güncelle</button>
                    </form>

                </div>
            </div>
        </div>
    </div>
</section>
