@model List<ResultKanalDto>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 0;
}

<section class="content container-fluid">
    <div class="row">

        <div class="col-md-12">
            <div class="chart-box">
                <div class="bs-example" data-example-id="bordered-table">
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Kanal Adı</th>
                                <th>Sil</th>
                                <th>Güncelle</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                count++;
                                <tr>
                                    <th scope="row">@count</th>
                                    <td>@item.KanalName</td>
                                   @*  <td><a href="/Admin/Kanal/DeleteKanal/@item.KanalId" class="btn btn-danger">Sil</a></td>
                                    <td><a href="/Admin/Kanal/UpdateKanal/@item.KanalId" class="btn btn-success">Güncelle</a></td> *@
                                </tr>
                            }
                        </tbody>
                    </table>
                   @*  <a href="/Admin/Kanal/CreateKanal/" class="btn btn-primary">Yeni Kanal Girişi</a> *@
                </div>
            </div>
        </div>



    </div>
</section>
