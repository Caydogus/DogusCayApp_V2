@model DogusCay.WebUI.Areas.Admin.Models.PivotViewModel
@{
    // Mevcut Layout ayarınız
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link rel="stylesheet" href="~/lib/ag-grid/ag-grid.css" />
<link rel="stylesheet" href="~/lib/ag-grid/ag-theme-balham.css" />

<style>
    /* * 🔥 BOŞLUK SIFIRLAMA 🔥: Üst boşlukları ve dolguları sıfırlayarak
         * içeriğin en üste, navigasyon barın altına yapışmasını sağlar.
         */
    .container-fluid {
        padding-top: 0 !important;
        margin-top: 0 !important;
    }

        /* İlk row'daki (başlık row) boşluğu sıfırlar */
        .container-fluid > .row:first-child {
            margin-top: 0 !important;
            margin-bottom: 0 !important;
        }

    /* Pivot Grid Yüksekliği ve Scrollbar Kontrolü */
    #pivotGrid {
        height: 800px;
        width: 100%;
        overflow-x: auto !important;
        margin-top: 0 !important;
    }

    /* Columns Panel görünmesi için zorunlu genişlik */
    .ag-theme-balham .ag-side-bar {
        width: 260px !important;
        min-width: 260px !important;
        max-width: 260px !important;
        border-left: 1px solid #ddd;
    }

    /* ✅ SÜTUN BAŞLIKLARI STİLİ: Kalın ve Modern görünüm (renderPivotGrid fonksiyonunda referans alınıyor) */
    .modern-header-cell {
        font-weight: bold !important;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif !important;
        color: #212529 !important;
    }
</style>

<div class="container-fluid">

    @* mt-1 sınıfı kaldırıldı, boşluk sıfırlandı *@
    <div class="row mb-1">
        <div class="col-12">
            <h3 class="fw-bold">@Model.Title</h3>
        </div>
    </div>

    @* mb-4 sınıfı mb-1 yapıldı *@
    <div class="card p-3 shadow-sm mb-1">
        <div class="row">
            <div class="col-md-4">
                <label class="form-label fw-bold">Tablolar</label>
                <select id="tableSelector" class="form-control">
                    <option value="">Seçiniz...</option>
                    @foreach (var tbl in Model.Tables)
                    {
                        <option value="@tbl">@tbl</option>
                    }
                </select>
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button id="btnLoadPivot" class="btn btn-primary w-100">
                    Verileri Getir
                </button>
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button id="btnExportExcel" class="btn btn-success w-100">
                    Excel'e Aktar
                </button>
            </div>

            @* JWT Token'ı saklamak için gizli alan, JavaScript tarafından kullanılacak *@
            <input type="hidden" id="jwtToken" value="@ViewBag.JwtToken" />

        </div>
    </div>

    <div id="pivotGrid" class="ag-theme-balham"></div>

</div>

<script src="~/lib/ag-grid/ag-grid-community.min.js"></script>

<script src="~/js/pivot.js"></script>