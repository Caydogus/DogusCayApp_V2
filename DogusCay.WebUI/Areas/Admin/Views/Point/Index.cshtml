@model List<ResultPointDto>
@{
    ViewData["Title"] = "Nokta Listesi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var currentPage = (int)ViewBag.CurrentPage;
    var totalPages = (int)ViewBag.TotalPages;
    var totalCount = (int)ViewBag.TotalCount;
    var pageSize = (int)ViewBag.PageSize;
    var displayRange = 2;
    var firstLastPagesToShow = 1;
}
<head>
    <link rel="stylesheet" href="~/css/point.css" asp-append-version="true" />
</head>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger" role="alert">@ViewBag.Error</div>
}

@if (Model == null || !Model.Any())
{
    <div class="alert alert-warning text-center">Hiç nokta bulunamadı.</div>
}
else
{
    <!-- MASAÜSTÜ TABLOSU -->
    <div class="table-responsive d-none d-md-block">
        <table class="table table-bordered table-striped table-hover text-nowrap" style="min-width: 1000px;">
            <thead class="bg-dark text-white">
                <tr>
                    <th>#</th>
                    <th>Nokta ERC</th>
                    <th>Nokta Adı</th>
                    <th>Nokta Grubu</th>
                    <th>Kanal Adı</th>
                    @if (User.IsInRole("Admin"))
                    {
                        <th>Bölge Müdürü</th>
                    }
                    <th>Distribütör Adı</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int startIndex = ((currentPage - 1) * pageSize) + 1;
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <th scope="row">@(startIndex++)</th>
                        <td>@(!string.IsNullOrWhiteSpace(item.PointErc) ? item.PointErc : "—")</td>
                        <td>@(!string.IsNullOrWhiteSpace(item.PointName) ? item.PointName : "—")</td>
                        <td>@(!string.IsNullOrWhiteSpace(item.PointGroupTypeName) ? item.PointGroupTypeName : "—")</td>
                        <td>@(!string.IsNullOrWhiteSpace(item.KanalName) ? item.KanalName : "—")</td>
                        @if (User.IsInRole("Admin"))
                        {
                            <td>@(!string.IsNullOrWhiteSpace(item.AppUserFullName) ? item.AppUserFullName : "—")</td>
                        }
                        <td>@(!string.IsNullOrWhiteSpace(item.DistributorName) ? item.DistributorName : "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- MOBİL KARTLAR -->
    <div class="d-md-none">
        @foreach (var item in Model)
        {
            <div class="point-card mb-3 p-2 rounded-3 shadow-sm">
                <div class="point-title">@item.PointName</div>
                <div class="point-fields mb-1">
                    <div class="field-row">
                        <span class="field-label">ERC:</span>
                        <span class="field-value">@item.PointErc</span>
                    </div>
                    <div class="field-row">
                        <span class="field-label">Grup:</span>
                        <span class="field-value">@item.PointGroupTypeName</span>
                    </div>
                    <div class="field-row">
                        <span class="field-label">Kanal:</span>
                        <span class="field-value">@item.KanalName</span>
                    </div>
                    @if (User.IsInRole("Admin"))
                    {
                        <div class="field-row">
                            <span class="field-label">Bölge Müdürü:</span>
                            <span class="field-value">@item.AppUserFullName</span>
                        </div>
                    }
                </div>
                <div class="field-row-full">
                    <span class="field-label">Distribütör:</span>
                    <span class="field-value">@item.DistributorName</span>
                </div>
            </div>
        }
    </div>

    @if (totalPages > 1)
    {
        <nav aria-label="Nokta Sayfalaması" class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { page = currentPage - 1 })" aria-label="Önceki">
                        <span aria-hidden="true">&laquo;</span><span class="sr-only">Önceki</span>
                    </a>
                </li>
                @{
                    var pageNumbers = new List<int>();
                    for (int i = 1; i <= firstLastPagesToShow && i <= totalPages; i++) if (!pageNumbers.Contains(i)) pageNumbers.Add(i);
                    for (int i = Math.Max(1, currentPage - displayRange); i <= Math.Min(totalPages, currentPage + displayRange); i++) if (!pageNumbers.Contains(i)) pageNumbers.Add(i);
                    for (int i = totalPages - firstLastPagesToShow + 1; i <= totalPages; i++) if (i > 0 && !pageNumbers.Contains(i)) pageNumbers.Add(i);
                    pageNumbers = pageNumbers.OrderBy(p => p).ToList();
                    int? lastPageNumber = null;
                    foreach (var pageNum in pageNumbers)
                    {
                        if (lastPageNumber.HasValue && pageNum > lastPageNumber + 1)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                        <li class="page-item @(pageNum == currentPage ? "active" : "")">
                            <a class="page-link" href="@Url.Action("Index", new { page = pageNum })">@pageNum</a>
                        </li>
                        lastPageNumber = pageNum;
                    }
                }
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { page = currentPage + 1 })" aria-label="Sonraki">
                        <span aria-hidden="true">&raquo;</span><span class="sr-only">Sonraki</span>
                    </a>
                </li>
            </ul>
        </nav>
        <p class="text-center mt-3">Toplam Kayıt: <b>@totalCount</b> | Sayfa @currentPage / @totalPages</p>
    }
}
