@model DogusCay.WebUI.DTOs.IhaleAnlasmaDtos.CreateIhaleAnlasmaSozlesmeViewModel
@{
    ViewData["Title"] = "";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h3 class="mb-4">Sözleşme Yükle</h3>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card p-4 shadow-sm" style="max-width:700px;">
    <form asp-action="CreateSozlesme" method="post" enctype="multipart/form-data">

        <input type="hidden" asp-for="NoktaKod" />

        <!-- İskonto -->
        <div class="form-group mb-3">
            <label asp-for="IskontoOrani" class="fw-bold">İskonto Oranı (%)</label>
            <input asp-for="IskontoOrani"
                   type="number"
                   class="form-control"
                   step="1" min="0" max="50" placeholder="Örn: 5" />
            <small class="text-muted">
                Boş bırakabilirsiniz. (İsteğe bağlı)
            </small>
        </div>

        <!-- Dosyalar -->
        <div class="form-group mb-3">
            <label asp-for="Dosyalar" class="fw-bold">Sözleşme Dosyaları</label>
            <input asp-for="Dosyalar"
                   type="file"
                   class="form-control"
                   multiple
                   accept=".jpg,.jpeg,.png,.pdf"
                   id="dosyaInput"
                   required />
            <small class="text-muted">
                PDF veya resim (JPG/PNG) yükleyebilirsiniz.
                Birden fazla dosya seçebilirsiniz. Maks. 50MB/dosya.
            </small>
        </div>

        <!-- Dosya önizleme -->
        <div id="previewArea" class="mb-3 d-flex flex-wrap gap-2"></div>

        <!-- Not -->
        <div class="form-group mb-3">
            <label asp-for="Note" class="fw-bold">Not (Opsiyonel)</label>
            <textarea asp-for="Note"
                      class="form-control"
                      rows="3"
                      placeholder="Eklemek istediğiniz not...(Kutu iskonto oranı girebilirsiniz)"></textarea>
        </div>

        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-secondary">← Geri</a>
            <button type="submit" class="btn btn-success" id="submitBtn">
                <i class="bi bi-upload"></i> Gönder
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.getElementById('dosyaInput').addEventListener('change', function (e) {
            const previewArea = document.getElementById('previewArea');
            previewArea.innerHTML = '';

            Array.from(e.target.files).forEach(file => {
                const div = document.createElement('div');
                div.style.cssText =
                    'border:1px solid #ddd;border-radius:8px;padding:8px;text-align:center;width:120px;';

                if (file.type.startsWith('image/')) {
                    const img = document.createElement('img');
                    img.src = URL.createObjectURL(file);
                    img.style.cssText =
                        'width:100px;height:80px;object-fit:cover;border-radius:4px;';
                    div.appendChild(img);
                } else {
                    div.innerHTML =
                        '<i class="bi bi-file-earmark-pdf" style="font-size:40px;color:#dc3545;"></i>';
                }

                const name = document.createElement('div');
                name.textContent = file.name.length > 15
                    ? file.name.substring(0, 12) + '...'
                    : file.name;
                name.style.cssText = 'font-size:11px;margin-top:4px;word-break:break-all;';
                div.appendChild(name);

                const size = document.createElement('div');
                size.textContent = (file.size / 1024 / 1024).toFixed(2) + ' MB';
                size.style.cssText = 'font-size:10px;color:#888;';
                div.appendChild(size);

                previewArea.appendChild(div);
            });
        });

        document.querySelector('form').addEventListener('submit', function () {
            const btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.innerHTML =
                '<span class="spinner-border spinner-border-sm"></span> Yükleniyor...';
        });
    </script>
}