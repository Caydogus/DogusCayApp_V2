@model EditIhaleAnlasmaSozlesmeViewModel
@inject IConfiguration Configuration
@{
    ViewData["Title"] = "";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    // ✅ API Base URL dinamik
    var apiBaseUrl = Configuration["ApiSettings:BaseUrl"];
    if (!string.IsNullOrEmpty(apiBaseUrl))
    {
        apiBaseUrl = apiBaseUrl.Replace("/api", "").TrimEnd('/');
    }
}

<h3 class="mb-4">Sözleşme Düzenle - @Model.NoktaAdi (@Model.NoktaKod)</h3>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<!-- MEVCUT DOSYALAR (form dışında) -->
@if (Model.MevcutDosyalar != null && Model.MevcutDosyalar.Any())
{
    <div class="card mb-4">
        <div class="card-header fw-bold" style="background:#25395a; color:#fff;">
            Mevcut Dosyalar (@Model.MevcutDosyalar.Count adet)
        </div>
        <div class="card-body">
            <div class="d-flex flex-wrap gap-3">
                @foreach (var dosya in Model.MevcutDosyalar)
                {
                    @* ✅ DÜZELTME – API base URL eklendi *@
                    var fullUrl = $"{apiBaseUrl}{dosya.DosyaYolu}";

                    <div class="text-center position-relative"
                         style="border:1px solid #e0e0e0; border-radius:10px; padding:10px; width:160px;">

                        @if (!string.IsNullOrEmpty(dosya.DosyaTipi) && dosya.DosyaTipi.StartsWith("image"))
                        {
                            <a href="@fullUrl" target="_blank">
                                <img src="@fullUrl"
                                     alt="@dosya.DosyaAdi"
                                     style="width:140px;height:110px;object-fit:cover;border-radius:6px;" />
                            </a>
                        }
                        else
                        {
                            <a href="@fullUrl" target="_blank">
                                <i class="bi bi-file-earmark-pdf" style="font-size:50px;color:#dc3545;"></i>
                                <div class="mt-1" style="font-size:12px;">PDF Görüntüle</div>
                            </a>
                        }

                    <div style="font-size:11px;color:#666;word-break:break-all;">
                        @(dosya.DosyaAdi != null && dosya.DosyaAdi.Length > 20
                                            ? dosya.DosyaAdi.Substring(0, 17) + "..."
                                            : dosya.DosyaAdi)
                </div>

                        <form method="post" asp-action="DeleteDosya"
                              asp-route-dosyaId="@dosya.IhaleAnlasmaDosyaId"
                              asp-route-sozlesmeId="@Model.IhaleAnlasmaSozlesmeId"
                              onsubmit="return confirm('Bu dosyayı silmek istediğinize emin misiniz?');">
                            <button type="submit" class="btn btn-sm btn-outline-danger w-100 mt-1">
                                <i class="bi bi-trash"></i> Sil
                            </button>
                        </form>
                    </div>
                        }
            </div>
        </div>
    </div>
}

<!-- GÜNCELLEME FORMU -->
<form method="post" enctype="multipart/form-data" id="editForm">
    <input type="hidden" asp-for="IhaleAnlasmaSozlesmeId" />
    <input type="hidden" asp-for="NoktaKod" />
    <input type="hidden" asp-for="NoktaAdi" />

    <!-- İSKONTO ORANI -->
    <div class="card mb-4">
        <div class="card-header fw-bold" style="background:#25395a; color:#fff;">
            Sözleşme Bilgileri
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="IskontoOrani" class="form-label fw-bold">İskonto Oranı (%)</label>
                    @* ✅ DÜZELTME – step="0.01" ve value InvariantCulture ile noktalı *@
                    <input name="IskontoOrani" id="IskontoOrani" class="form-control" type="number"
                           step="0.01" min="0" max="50" placeholder="Örn: 5"
                           value="@(Model.IskontoOrani.HasValue ? ((int)Model.IskontoOrani.Value == Model.IskontoOrani.Value ? Model.IskontoOrani.Value.ToString("0") : Model.IskontoOrani.Value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)) : "")" />
                    <span asp-validation-for="IskontoOrani" class="text-danger"></span>
                </div>
                <div class="col-md-8 mb-3">
                    <label asp-for="Note" class="form-label fw-bold">Not (Opsiyonel)</label>
                    <textarea asp-for="Note" class="form-control" rows="2"
                              placeholder="Açıklama ekleyebilirsiniz..."></textarea>
                </div>
            </div>
        </div>
    </div>

    <!-- YENİ DOSYA EKLE -->
    <div class="card mb-4">
        <div class="card-header fw-bold" style="background:#25395a; color:#fff;">
            Yeni Dosya Ekle
        </div>
        <div class="card-body">
            <input type="file" asp-for="YeniDosyalar" class="form-control"
                   multiple accept=".jpg,.jpeg,.png,.pdf" />
            <small class="text-muted">JPG, PNG veya PDF. Maksimum 50MB/dosya.</small>
            <div id="previewArea" class="d-flex flex-wrap gap-2 mt-3"></div>
        </div>
    </div>

    <!-- BUTONLAR -->
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-success" id="btnSubmit">
            <i class="bi bi-check-circle"></i> Güncelle
        </button>
        <a asp-action="Detail" asp-route-id="@Model.IhaleAnlasmaSozlesmeId"
           class="btn btn-secondary">
            ← İptal
        </a>
    </div>
</form>

@section Scripts {
    <script>
        document.getElementById('YeniDosyalar').addEventListener('change', function () {
            const preview = document.getElementById('previewArea');
            preview.innerHTML = '';
            Array.from(this.files).forEach(file => {
                const div = document.createElement('div');
                div.style.cssText = 'border:1px solid #ddd;border-radius:8px;padding:8px;width:130px;text-align:center;';

                if (file.type.startsWith('image/')) {
                    const img = document.createElement('img');
                    img.style.cssText = 'width:110px;height:90px;object-fit:cover;border-radius:4px;';
                    const reader = new FileReader();
                    reader.onload = e => img.src = e.target.result;
                    reader.readAsDataURL(file);
                    div.appendChild(img);
                } else {
                    div.innerHTML = '<i class="bi bi-file-earmark-pdf" style="font-size:40px;color:#dc3545;"></i>';
                }

                const name = document.createElement('div');
                name.style.cssText = 'font-size:11px;color:#666;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;';
                name.textContent = file.name;
                div.appendChild(name);

                preview.appendChild(div);
            });
        });

        document.getElementById('editForm').addEventListener('submit', function () {
            var btn = document.getElementById('btnSubmit');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Güncelleniyor...';
        });
    </script>
}
