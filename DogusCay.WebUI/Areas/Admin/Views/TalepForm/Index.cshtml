@model List<ResultTalepFormDto>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>Talep Formları</h2>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>#</th>
            <th>Kullanıcı</th>
            <th>Kanal</th>
            <th>Distributor</th>
            <th>Nokta Grubu</th>
            <th>Nokta</th>
            <th>Tip</th>
            <th>Durum</th>
            <th>Tarih</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.TalepFormId</td>
                <td>@item.UserFullName</td>
                <td>@item.KanalName</td>
                <td>@item.DistributorName</td>
                <td>@item.PointGroupTypeName</td>
                <td>@item.PointName</td>
                <td>@item.TalepTip</td>
                <td>@item.TalepDurumu</td>
                <td>@item.ValidFrom.ToShortDateString() - @item.ValidTo.ToShortDateString()</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.TalepFormId">Detay</a>
                </td>
            </tr>
        }
    </tbody>
</table>