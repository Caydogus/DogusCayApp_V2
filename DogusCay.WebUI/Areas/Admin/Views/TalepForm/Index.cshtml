@model List<ResultTalepFormDto>
@{
    ViewData["Title"] = "";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var jwt = Context.Session.GetString("JwtToken");
}
<input type="hidden" id="jwtToken" value="@jwt" />
<h3 class="mb-4 d-flex justify-content-between align-items-center">
    <a class="btn btn-success" asp-area="Admin" asp-controller="TalepForm" asp-action="CreateTalepForm">+ Yeni Talep Oluştur</a>
</h3>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-warning">Hiç talep formu bulunamadı.</div>
}
else
{
    <div class="table-responsive" style="overflow-x:auto; max-width:100%;">
        <table class="table table-striped table-hover text-nowrap" style="min-width: 1300px;">
            <thead class="bg-dark text-white">
                <tr>
                    <th></th>
                    <th>Kampaya Tarihi</th>
                    <th>Müşteri</th>
                    <th>Ürün Adı</th>
                    <th>Kategori</th>
                    <th>Alt Kategori</th>
                    <th>Marka</th>
                    <th>ERP Kodu</th>
                    <th>Ağırlık (kg)</th>
                    <th>Adet Farkı (₺)</th>
                    <th>Son Adet Fiyatı</th>
                    <th>Toplam (₺)</th>
                    <th>Maliyet</th>
                    <th>Kampanya Dönüşü Miktarı</th>
                    <th>Durum</th>
                    @if (User.IsInRole("Admin")) { <th>İşlemler</th>}
                    <th>Kampanya Dönüşü</th>
                    <th>Kampanya Görseli</th>
                    

                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <button class="btn btn-danger btn-sm" onclick="deleteTalep(@item.TalepFormId)">Sil</button>
                        </td>
                        <td>@item.ValidFrom.ToShortDateString() - @item.ValidTo.ToShortDateString()</td>
                        <td>@item.PointName</td>
                        <td>@item.ProductName</td>
                        <td>@item.CategoryName</td>
                        <td>@item.SubCategoryName</td>
                        <td>@item.SubSubCategoryName</td>
                        <td>@item.ErpCode</td>
                        <td>@item.ApproximateWeightKg.ToString("0.00")</td>
                        <td>@item.AdetFarkDonusuTL.ToString("C2")</td>
                        <td>@item.SonAdetFiyati.ToString("C2")</td>
                        <td class="fw-bold">@item.Total.ToString("C2")</td>
                        <td>@item.Maliyet</td>
						<td>@item.KampanyaDonusAdedi</td>
                        <!-- Durum Gösterimi -->
                        <td>
                            @if (item.TalepDurumu == 0)
                            {
                                <span class="badge bg-warning text-dark">Bekliyor</span>
                            }
                            else if (item.TalepDurumu == TalepDurumu.Onaylandi)
                            {
                                <span class="badge bg-success">Onaylandı</span>
                            }
                            else if (item.TalepDurumu == TalepDurumu.Reddedildi)
                            {
                                <span class="badge bg-danger">Reddedildi</span>
                            }
                        </td>
                        <!-- İşlem Butonları -->
                        @if (User.IsInRole("Admin"))
                        {
                            <td>
                                @if (item.TalepDurumu == 0)
                                {
                                    <button class="btn btn-success btn-sm" onclick="approveTalep(@item.TalepFormId)">Onayla</button>
                                    <button class="btn btn-danger btn-sm" onclick="rejectTalep(@item.TalepFormId)">Reddet</button>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>
                        }
   
                        <!-- Kampanya donuş adedi -->
                        <td>
                            @if (item.TalepDurumu == TalepDurumu.Onaylandi && User.IsInRole("BolgeMuduru"))
                            {
                                <input type="hidden" id="koliIciToplamAdet_@item.TalepFormId" value="@item.KoliIciToplamAdet" />
                                <input type="number" id="kampanyaInput_@item.TalepFormId" class="form-control form-control-sm d-inline-block" style="width: 80px;" min="0" placeholder="Adet" />
                                <button class="btn btn-primary btn-sm" onclick="gonderKampanyaDonusu(@item.TalepFormId)">Kaydet</button>
                            }
                            else if (item.KampanyaDonusAdedi.HasValue)
                            {
                                <span>@item.KampanyaDonusAdedi.Value adet</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <!-- Kampanya resmi ekleme -->
                        <td style="white-space: nowrap;">
                            @if (item.TalepDurumu == TalepDurumu.Onaylandi && User.IsInRole("BolgeMuduru"))
                            {
                                <div style="display: flex; align-items: center; gap: 10px;">
                                    <div style="flex-shrink: 0;">
                                        <input type="file"
                                               id="imageInput_@item.TalepFormId"
                                               accept="image/*"
                                               style="width: 140px; padding: 3px;" />
                                    </div>

                                    <button class="btn btn-sm btn-info" onclick="uploadImage(@item.TalepFormId)">Yükle</button>

                                    @if (!string.IsNullOrEmpty(item.KampanyaResimYolu))
                                    {
                                        <a href="@item.KampanyaResimYolu"
                                           target="_blank"
                                           class="text-decoration-underline"
                                           style="color: #1a73e8; font-size: 0.9rem;"
                                           title="Yüklenmiş resmi görüntüle">
                                            📷 Resmi Aç
                                        </a>
                                    }
                                </div>
                            }
                            else if (!string.IsNullOrEmpty(item.KampanyaResimYolu))
                            {
                                <a href="@item.KampanyaResimYolu"
                                   target="_blank"
                                   class="text-decoration-underline"
                                   style="color: #d62828; font-size: 0.9rem;"
                                   title="Yüklenmiş resmi görüntüle">
                                    📷 Resmi Aç
                                </a>
                            }
                        </td>

                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (ViewBag.TotalPages > 1)
    {
        <nav class="mt-4 d-flex justify-content-center">
            <ul class="pagination pagination-sm">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" href="?page=@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }

}

@section Scripts {
    <script src="~/js/talepFormuIndex.js" asp-append-version="true"></script>
}