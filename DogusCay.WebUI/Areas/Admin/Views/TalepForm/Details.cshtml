
@model ResultTalepFormDto

@{
    ViewData["Title"] = "Talep Detayı";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>Talep Detayı (#@Model.TalepFormId)</h2>

<hr />
<div class="row mb-3">
    <div class="col-md-6">
        <p><strong>Talep Tipi:</strong> @Model.TalepTip</p>
        <p><strong>Talep Durumu:</strong> @Model.TalepDurumu</p>
        <p><strong>Başlangıç Tarihi:</strong> @Model.ValidFrom.ToShortDateString()</p>
        <p><strong>Bitiş Tarihi:</strong> @Model.ValidTo.ToShortDateString()</p>
        <p><strong>Not:</strong> @Model.Note</p>
    </div>
    <div class="col-md-6">
        <p><strong>Kullanıcı:</strong> @Model.UserFullName</p>
        <p><strong>Kanal:</strong> @Model.KanalName</p>
        @if (!string.IsNullOrEmpty(Model.DistributorName))
        {
            <p><strong>Distribütör:</strong> @Model.DistributorName</p>
        }
        @if (!string.IsNullOrEmpty(Model.PointGroupTypeName))
        {
            <p><strong>Nokta Grubu:</strong> @Model.PointGroupTypeName</p>
        }
        <p><strong>Nokta:</strong> @Model.PointName</p>
    </div>
</div>

<h4>Ürün Bilgisi</h4>
<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Ürün Adı</th>
            <th>Adet</th>
            <th>Fiyat</th>
            <th>Koli İçi</th>
            <th>Kg</th>
            <th>İskonto 1</th>
            <th>İskonto 2</th>
            <th>İskonto 3</th>
            <th>İskonto 4</th>
            <th>Geçerlilik</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.ProductName</td>
                <td>@item.Quantity</td>
                <td>@item.Price.ToString("C")</td>
                <td>@item.KoliIciAdet</td>
                <td>@item.ApproximateWeightKg</td>
                <td>@item.Iskonto1</td>
                <td>@item.Iskonto2</td>
                <td>@item.Iskonto3</td>
                <td>@item.Iskonto4</td>
                <td>@item.ValidFrom.ToShortDateString() - @item.ValidTo.ToShortDateString()</td>
            </tr>
        }
    </tbody>
</table>

<a href="@Url.Action("Index")" class="btn btn-secondary">Listeye Dön</a>
