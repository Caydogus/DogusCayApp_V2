@model DogusCay.WebUI.DTOs.TalepFormDtos.CreateTalepFormDto

@{
	ViewData["Title"] = "Insert Tipi Talep Formu";
	Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h3 class="mb-3">Insert Tipi Talep Formu</h3>


<form id="talepForm">
	<div class="row">
		<input asp-for="AppUserId" type="hidden" value="9" />
		<div class="row">
			<!-- Kanal -->
			<div class="form-group col-md-4">
				<label for="KanalId">Kanal</label>
				<select asp-for="KanalId" class="form-control" style="font-size:16px; min-width:220px;" id="KanalId" asp-items="ViewBag.Kanallar">
					<option value="">Seçiniz</option>
				</select>
			</div>

			<!-- Distributor (Başlangıçta gizli) -->
			<div class="form-group col-md-4" id="distributorDiv" style="display:none;">
				<label for="DistributorId">Distributor</label>
				<select asp-for="DistributorId" class="form-control" id="DistributorId">
					<option value="">Seçiniz</option>
				</select>
			</div>

			<!-- Nokta Grubu (Başlangıçta gizli) -->
			<div class="form-group col-md-4" id="pointGroupDiv" style="display:none;">
				<label for="PointGroupTypeId">Nokta Grubu</label>
				<select asp-for="PointGroupTypeId" class="form-control" id="PointGroupTypeId">
					<option value="">Seçiniz</option>
				</select>
			</div>

			<!-- Nokta -->
			<div class="form-group col-md-4" id="pointDiv">
				<label for="PointId">Nokta</label>
				<select asp-for="PointId" class="form-control" id="PointId">
					<option value="">Seçiniz</option>
				</select>
			</div>
		</div>
		<!-- Ana Kategori -->
		<div class="form-group col-md-4">
			<label for="CategoryId">Ana Kategori</label>
			<select asp-for="CategoryId" class="form-control" id="CategoryId">
				<option value="">Seçiniz</option>
			</select>
		</div>

		<!-- Alt Kategori -->
		<div class="form-group col-md-4">
			<label for="SubCategoryId">Alt Kategori</label>
			<select asp-for="SubCategoryId" class="form-control" id="SubCategoryId">
				<option value="">Önce ana kategori seçiniz</option>
			</select>
		</div>

		<!-- Alt Alt Kategori -->
		<div class="form-group col-md-4">
			<label for="SubSubCategoryId">Alt Alt Kategori</label>
			<select asp-for="SubSubCategoryId" class="form-control" id="SubSubCategoryId">
				<option value="">Önce alt kategori seçiniz</option>
			</select>
		</div>


		<!-- Ürün (zaten vardı ama kontrol edelim) -->
		<div class="form-group col-md-4">
			<label for="ProductId">Ürün</label>
			<select asp-for="ProductId" class="form-control" id="ProductId">
				<option value="">Önce alt kategori seçiniz</option>
			</select>
		</div>


		<!-- Erp Kodu -->
		<div class="form-group col-md-3">
			<label for="ErpCode">ERP</label>
			<input asp-for="ErpCode" class="form-control" id="ErpCode" readonly />
		</div>

		<!-- Koli İçi Adet formda gizli -->
		<input asp-for="KoliIciAdet" class="form-control" id="KoliIciAdet" readonly type="hidden" />
		<!-- Fiyat formda gizli -->
		<input asp-for="Price" class="form-control" id="Price" type="hidden" />
		<!-- Yaklaşık Kg formda gizli-->
		<input asp-for="ApproximateWeightKg" class="form-control" id="ApproximateWeightKg" readonly type="hidden" />

		<!-- Adet -->
		<div class="form-group col-md-3">
			<label for="Quantity">Adet</label>
			<input asp-for="Quantity" class="form-control" id="Quantity" />
		</div>



		<div class="col-md-12">
			<div class="border rounded p-3 bg-light">
				<h6 class="mb-3">İskonto ve Adet Farkı</h6>
				<div class="row">
					<!-- Sol Göz -->
					<div class="col-md-6">
						<div class="form-group mb-2">
							<label for="Iskonto1">İskonto 1 (%)</label>
							<input asp-for="Iskonto1" class="form-control" />
						</div>
						<div class="form-group mb-2">
							<label for="Iskonto2">İskonto 2 (%)</label>
							<input asp-for="Iskonto2" class="form-control" />
						</div>
						<div class="form-group mb-0">
							<label for="Iskonto3">İskonto 3 (%)</label>
							<input asp-for="Iskonto3" class="form-control" />
						</div>
					</div>

					<!-- Sağ Göz -->
					<div class="col-md-6">
						<div class="row">
							<div class="form-group col-md-6">
								<label for="Iskonto4">Adet Fark (%)</label>
								<input asp-for="Iskonto4" class="form-control" />
							</div>
							<div class="form-group col-md-6">
								<label for="AdetFarkDonusuTL">Adet Farkı (₺)</label>
								<input asp-for="AdetFarkDonusuTL" class="form-control" />
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>


		<!-- Hesaplanan Alanlar -->
		<!-- 🔁 Toplam Tutar -->
		<input asp-for="Total" type="hidden" id="Total" />
		<div class="form-group col-md-3">
			<label>Toplam Tutar (₺)</label>
			<input class="form-control" id="TotalDisplay" readonly />
		</div>

		<!-- 🔁 Liste Fiyatı -->
		<input asp-for="ListeFiyat" type="hidden" id="ListeFiyat" />
		<div class="form-group col-md-3">
			<label>Liste Fiyatı (₺)</label>
			<input class="form-control" id="ListeFiyatDisplay" readonly />
		</div>

		<!-- 🔁 Son Adet Fiyatı -->
		<input asp-for="SonAdetFiyati" type="hidden" id="SonAdetFiyati" />
		<div class="form-group col-md-3">
			<label>Son Adet Fiyatı (₺)</label>
			<input class="form-control" id="SonAdetFiyatiDisplay" readonly />
		</div>

		<!-- 🔁 Koli İçi Toplam Adet -->
		<input asp-for="KoliIciToplamAdet" type="hidden" id="KoliIciToplamAdet" />
		<div class="form-group col-md-3">
			<label>Koli İçi Toplam Adet</label>
			<input class="form-control" id="KoliIciToplamAdetDisplay" readonly />
		</div>

		<!-- 🔁 Koli Toplam Ağırlığı -->
		<input asp-for="KoliToplamAgirligiKg" type="hidden" id="KoliToplamAgirligiKg" />
		<div class="form-group col-md-3">
			<label>Toplam Koli Ağırlığı (kg)</label>
			<input class="form-control" id="KoliToplamAgirligiKgDisplay" readonly />
		</div>



		<!-- Sabit Bedel ve Adet Farkı -->
		<div class="form-group col-md-3">
			<label for="SabitBedelTL">Sabit Bedel (₺)</label>
			<input asp-for="SabitBedelTL" class="form-control" />
		</div>

		<!-- Tarihler -->
		<div class="form-group col-md-3">
			<label for="ValidFrom">Başlangıç Tarihi</label>
			<input asp-for="ValidFrom" id="ValidFrom" type="date" class="form-control" />
		</div>
		<div class="form-group col-md-3">
			<label for="ValidTo">Bitiş Tarihi</label>
			<input asp-for="ValidTo" id="ValidTo" type="date" class="form-control" />
		</div>

		<!-- Not -->
		<div class="form-group col-md-12">
			<label for="Note">Açıklama</label>
			<textarea asp-for="Note" class="form-control" rows="2"></textarea>
		</div>

	</div>

	<button type="submit" class="btn btn-success mt-3">Talep Oluştur</button>
</form>
@section Scripts {
	<script>
		$(document).ready(function () {
			const apiBaseUrl = "https://localhost:7076/api";

			$('#distributorDiv, #pointGroupDiv').hide();

			// -------------------------- Kategori Zinciri --------------------------

			// Ana kategorileri getir (sayfa ilk açıldığında)
			$.get(`${apiBaseUrl}/categories/MainCategories`, function (data) {
				const catSelect = $('#CategoryId');
				catSelect.empty().append('<option value="">Seçiniz</option>');
				data.forEach(cat => {
					catSelect.append(`<option value="${cat.categoryId}">${cat.categoryName}</option>`);
				});
			});

				  // 1. Ana kategorileri yükle
		$.get(`${apiBaseUrl}/categories/MainCategories`, function (data) {
			const catSelect = $('#CategoryId');
			catSelect.empty().append('<option value="">Seçiniz</option>');
			data.forEach(cat => {
				catSelect.append(`<option value="${cat.categoryId}">${cat.categoryName}</option>`);
			});
		});

		// 2. Ana kategori → Alt kategori
		$('#CategoryId').change(function () {
			const categoryId = $(this).val();
			$('#SubCategoryId').empty().append('<option value="">Yükleniyor...</option>');
			$('#SubSubCategoryId').empty().append('<option value="">Önce alt kategori seçiniz</option>');
			$('#ProductId').empty().append('<option value="">Ürün bekleniyor...</option>');

			if (categoryId) {
				$.get(`${apiBaseUrl}/categories/${categoryId}/children`, function (data) {
					const subSelect = $('#SubCategoryId');
					subSelect.empty().append('<option value="">Seçiniz</option>');
					data.forEach(sub => {
						subSelect.append(`<option value="${sub.categoryId}">${sub.categoryName}</option>`);
					});
				});
			}
		});

		// 3. Alt kategori → AltAlt kategori
		$('#SubCategoryId').change(function () {
			const subCategoryId = $(this).val();
			$('#SubSubCategoryId').empty().append('<option value="">Yükleniyor...</option>');
			$('#ProductId').empty().append('<option value="">Ürün bekleniyor...</option>');

			if (subCategoryId) {
				$.get(`${apiBaseUrl}/categories/${subCategoryId}/children`, function (data) {
					const subSubSelect = $('#SubSubCategoryId');
					subSubSelect.empty().append('<option value="">Seçiniz</option>');
					data.forEach(subsub => {
						subSubSelect.append(`<option value="${subsub.categoryId}">${subsub.categoryName}</option>`);
					});
				});
			}
		});

		// 4. AltAlt kategori → Ürün
		$('#SubSubCategoryId').change(function () {
			const subSubCategoryId = $(this).val();
			$('#ProductId').empty().append('<option value="">Yükleniyor...</option>');

			if (subSubCategoryId) {
				$.get(`${apiBaseUrl}/categories/${subSubCategoryId}/products`, function (data) {
					const productSelect = $('#ProductId');
					productSelect.empty().append('<option value="">Seçiniz</option>');
					data.forEach(p => {
						productSelect.append(`<option value="${p.productId}">${p.productName}</option>`);
					});
				});
			}
		});


			// -------------------------- Kanal → Nokta zinciri --------------------------

			$('#KanalId').change(function () {
				const kanalId = $(this).val();
				$('#DistributorId, #PointGroupTypeId, #PointId').empty().append('<option value="">Seçiniz</option>');

				if (kanalId === "4") { // DIST
					$('#distributorDiv').show();
					$('#pointGroupDiv').hide();

					$.get(`${apiBaseUrl}/distributors/by-kanal/${kanalId}`)
						.done(data => {
							const select = $('#DistributorId');
							data.forEach(d => {
								select.append(`<option value="${d.distributorId}">${d.distributorName}</option>`);
							});
						})
						.fail(() => alert("❌ Distributor verisi alınamadı."));
				} else if (kanalId === "5" || kanalId === "6") {
					$('#distributorDiv, #pointGroupDiv').hide();

					$.get(`${apiBaseUrl}/points/by-kanal/${kanalId}`)
						.done(data => {
							const select = $('#PointId');
							select.empty().append('<option value="">Seçiniz</option>');
							data.forEach(p => {
								select.append(`<option value="${p.pointId}">${p.pointName}</option>`);
							});
						})
						.fail(() => alert("❌ Nokta verisi alınamadı."));
				} else {
					$('#distributorDiv, #pointGroupDiv').hide();
				}
			});

			$('#DistributorId').change(function () {
				const distributorId = $(this).val();
				$('#PointGroupTypeId, #PointId').empty().append('<option value="">Seçiniz</option>');

				if (distributorId) {
					$.get(`${apiBaseUrl}/pointgrouptypes/by-distributor/${distributorId}`)
						.done(data => {
							const select = $('#PointGroupTypeId');
							data.forEach(g => {
								select.append(`<option value="${g.pointGroupTypeId}">${g.pointGroupTypeName}</option>`);
							});
							$('#pointGroupDiv').show();
						})
						.fail(() => alert("❌ Nokta grubu verisi alınamadı."));
				} else {
					$('#pointGroupDiv').hide();
				}
			});

			$('#PointGroupTypeId').change(function () {
				const groupId = $(this).val();
				const distributorId = $('#DistributorId').val();
				$('#PointId').empty().append('<option value="">Seçiniz</option>');

				if (groupId && distributorId) {
					$.get(`${apiBaseUrl}/points/by-group/${groupId}/distributor/${distributorId}`)
						.done(data => {
							const select = $('#PointId');
							data.forEach(p => {
								select.append(`<option value="${p.pointId}">${p.pointName}</option>`);
							});
						})
						.fail(() => alert("❌ Nokta verisi alınamadı."));
				}
			});

			// -------------------------- Ürün detaylarını doldur --------------------------

			$('#ProductId').change(function () {
				const productId = $(this).val();
				if (productId) {
					$.get(`${apiBaseUrl}/products/get-product-info/${productId}`)
						.done(data => {
							$('#Price').val(data.price || '');
							$('#KoliIciAdet').val(data.koliIciAdet || '');
							$('#ApproximateWeightKg').val(data.approximateWeightKg || '');
							$('#ErpCode').val(data.erpCode || '');
							$('#Quantity').val(1);
							hesaplaIskonto();
						})
						.fail(() => alert("❌ Ürün bilgisi alınamadı."));
				}
			});

			// -------------------------- Hesaplama --------------------------

			$('#Price, #Quantity, #Iskonto1, #Iskonto2, #Iskonto3, #Iskonto4, #AdetFarkDonusuTL').on('input', hesaplaIskonto);

			function hesaplaIskonto() {
				const safeParse = sel => parseFloat($(sel).val()?.toString().replace(",", ".")) || 0;

				const price = safeParse('#Price');
				let quantity = safeParse('#Quantity');
				const isk1 = safeParse('#Iskonto1');
				const isk2 = safeParse('#Iskonto2');
				const isk3 = safeParse('#Iskonto3');
				const isk4 = safeParse('#Iskonto4');
				const adetFarkTL = safeParse('#AdetFarkDonusuTL');
				const approxKg = safeParse('#ApproximateWeightKg');
				const koliIci = parseInt($('#KoliIciAdet').val()) || 0;

				if (quantity < 1) {
					quantity = 1;
					$('#Quantity').val(1);
				}

				let toplam = price * quantity;
				[isk1, isk2, isk3, isk4].forEach(isk => {
					if (isk > 0) toplam *= (100 - isk) / 100;
				});

				const koliIciToplamAdet = quantity * koliIci;
				const koliToplamAgirligi = (quantity * approxKg).toFixed(2);
				const listeFiyat = koliIci > 0 ? (price / koliIci).toFixed(2) : "0.00";
				let sonAdetFiyat = koliIciToplamAdet > 0 ? toplam / koliIciToplamAdet : 0;

				if (adetFarkTL > 0) {
					sonAdetFiyat -= adetFarkTL;
					toplam = sonAdetFiyat * koliIciToplamAdet;
				}

				const total = toplam.toFixed(2);
				const sonAdetFiyatFormatted = sonAdetFiyat.toFixed(2);

				$('#Total').val(total);
				$('#KoliToplamAgirligiKg').val(koliToplamAgirligi);
				$('#KoliIciToplamAdet').val(koliIciToplamAdet);
				$('#ListeFiyat').val(listeFiyat);
				$('#SonAdetFiyati').val(sonAdetFiyatFormatted);

				$('#TotalDisplay').val(total);
				$('#KoliToplamAgirligiKgDisplay').val(koliToplamAgirligi);
				$('#KoliIciToplamAdetDisplay').val(koliIciToplamAdet);
				$('#ListeFiyatDisplay').val(listeFiyat);
				$('#SonAdetFiyatiDisplay').val(sonAdetFiyatFormatted);
			}

			// -------------------------- Tarihler --------------------------

			const today = new Date().toISOString().split('T')[0];
			const nextWeek = new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];
			$('#ValidFrom').val(today);
			$('#ValidTo').val(nextWeek);

			// -------------------------- Form Submit (fetch) --------------------------

			$('#talepForm').on('submit', async function (e) {
				e.preventDefault();

				const dto = {
					kanalId: parseInt($('#KanalId').val()) || 0,
					distributorId: parseInt($('#DistributorId').val()) || null,
					pointGroupTypeId: parseInt($('#PointGroupTypeId').val()) || null,
					pointId: parseInt($('#PointId').val()) || null,

					// 🔗 Yeni kategori alanları
					categoryId: parseInt($('#CategoryId').val()) || 0,
					subCategoryId: parseInt($('#SubCategoryId').val()) || null,
					subSubCategoryId: parseInt($('#SubSubCategoryId').val()) || null,


					productId: parseInt($('#ProductId').val()) || 0,
					productName: $('#ProductId option:selected').text(),
					erpCode: $('#ErpCode').val(),
					approximateWeightKg: parseFloat($('#ApproximateWeightKg').val()) || 0,
					koliIciAdet: parseInt($('#KoliIciAdet').val()) || 0,
					sabitBedelTL: parseFloat($('#SabitBedelTL').val()) || 0,
					quantity: parseInt($('#Quantity').val()) || 1,
					price: parseFloat($('#Price').val()) || 0,
					iskonto1: parseFloat($('#Iskonto1').val()) || 0,
					iskonto2: parseFloat($('#Iskonto2').val()) || 0,
					iskonto3: parseFloat($('#Iskonto3').val()) || 0,
					iskonto4: parseFloat($('#Iskonto4').val()) || 0,
					koliToplamAgirligiKg: parseFloat($('#KoliToplamAgirligiKg').val()) || 0,
					koliIciToplamAdet: parseInt($('#KoliIciToplamAdet').val()) || 0,
					listeFiyat: parseFloat($('#ListeFiyat').val()) || 0,
					sonAdetFiyati: parseFloat($('#SonAdetFiyati').val()) || 0,
					adetFarkDonusuTL: parseFloat($('#AdetFarkDonusuTL').val()) || 0,
					validFrom: $('#ValidFrom').val(),
					validTo: $('#ValidTo').val(),
					note: $('#Note').val(),
					appUserId: parseInt($('#AppUserId').val()) || 9,
					total: parseFloat($('#Total').val()) || 0
				};

				try {
					const res = await fetch(`${apiBaseUrl}/talepforms`, {
						method: "POST",
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify(dto)
					});

					const resultText = await res.text();
					console.log("📤 API yanıtı:", resultText);

					if (res.ok) {
						alert("✅ Talep başarıyla oluşturuldu.");
						window.location.href = "/Admin/TalepForm/Index";
					} else {
						alert("❌ Talep kaydedilemedi:\n" + resultText);
					}
				} catch (err) {
					console.error("❌ JavaScript Catch Hatası:", err);
					alert("Bir hata oluştu: " + (err.message || "Bilinmeyen hata"));
				}
			});
		});
	</script>
}






















