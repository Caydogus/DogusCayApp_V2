@model ResultMalYuklemeTalepFormDto
@{
    ViewData["Title"] = "";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h3 class="mb-4">Talep Detayı - #@Model.MalYuklemeTalepFormId</h3>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="card mb-4">
    <div class="card-header bg-secondary text-white">Genel Bilgiler</div>
    <div class="card-body row">
        <div class="col-md-4"><strong>Kullanıcı:</strong> @Model.AppUser?.FirstName @Model.AppUser?.LastName</div>
        <div class="col-md-4"><strong>Kanal:</strong> @Model.Kanal?.KanalName</div>
        <div class="col-md-4"><strong>Point:</strong> @Model.Point?.PointName</div>
        <div class="col-md-4 mt-2"><strong>Tarih:</strong> @Model.CreateDate.ToShortDateString()</div>
        <div class="col-md-4 mt-2">
            <strong>Durum:</strong>
            <span class="badge
                @(Model.TalepDurumu == TalepDurumu.Onaylandi ? "bg-success" :
                  Model.TalepDurumu == TalepDurumu.Reddedildi ? "bg-danger" :
                  "bg-warning text-dark")">
                @Model.TalepDurumu
            </span>
        </div>
        <div class="col-md-4 mt-2"><strong>Net Tutar:</strong> @Model.Total?.ToString("C2")</div>
        <div class="col-md-4 mt-2"><strong>Brüt Tutar:</strong> @Model.BrutTotal?.ToString("C2")</div>
        <div class="col-md-4 mt-2"><strong>Toplam Ağırlık:</strong> @Model.ToplamAgirlikKg?.ToString("N2") kg</div>
        <div class="col-md-4 mt-2"><strong>Maliyet:</strong> @Model.Maliyet?.ToString("N2") %</div>
    </div>
</div>

@if (Model.MalYuklemeTalepFormDetails != null && Model.MalYuklemeTalepFormDetails.Any())
{
    <div class="card">
        <div class="card-header bg-dark text-white">Ürün Detayları</div>
        <div class="card-body table-responsive">
            <table class="table table-bordered table-striped text-nowrap">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Ürün Adı</th>
                        <th>ERP Kodu</th>
                        <th>Tonaj(kg)</th>
                        <th>Toplam Adet</th>
                        <th>Brüt Tutar</th>
                        <th>İskonto 1 (%)</th>
                        <th>İskonto 2 (%)</th>
                        <th>Sabit Bedel</th>
                        <th>Net Tutar</th>
                        <th>Net Adet Fiyatı</th>
                        <th>Maliyet (%)</th>
                    </tr>
                </thead>
               
                <tbody>
                    @foreach (var d in Model.MalYuklemeTalepFormDetails)
                    {
                        <tr>
                            <td>@d.ResultMalYuklemeTalepFormDetailId</td>
                            <td>@d.ProductName</td>
                            <td>@d.ErpCode</td>
                            <td>@((d.ApproximateWeightKg * d.Quantity).ToString("N2"))</td> <!-- Toplam Ağırlık -->
                            <td>@(d.Quantity * d.KoliIciAdet)</td> <!-- EKLENDİ -->
                            <td>@d.BrutTutar?.ToString("C2")</td>
                            <td>@d.Discount1?.ToString("N2")</td>
                            <td>@d.Discount2?.ToString("N2")</td>
                            <td>@d.FixedPrice?.ToString("C2")</td>
                            <td>@d.NetTutar?.ToString("C2")</td>
                            <td>@d.NetAdetFiyat?.ToString("C2")</td>
                            <td>@(d.Maliyet.HasValue ? (d.Maliyet.Value * 100).ToString("N2") + " %" : "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-info">Bu talebe ait ürün detayı bulunamadı.</div>
}

<a asp-action="Index" class="btn btn-secondary mt-4">← Geri Dön</a>
