@model List<ResultMalYuklemeTalepFormDto>
@{
    ViewData["Title"] = "";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var jwt = Context.Session.GetString("JwtToken");
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var pageSize = (int)(ViewBag.PageSize ?? 10);
    var totalCount = (int)(ViewBag.TotalCount ?? 0);
    var displayRange = 2;
    var firstLastPagesToShow = 1;
}
<head>
    <link rel="stylesheet" href="~/css/malyukleme.css" asp-append-version="true" />
</head>
<input type="hidden" id="jwtToken" value="@jwt" />

@* <h3 class="mb-4 d-flex justify-content-between align-items-center">
    <a class="btn btn-success" asp-area="Admin" asp-controller="MalYuklemeTalepForm" asp-action="CreateMalYuklemeTalepForm">+ Ürün Talebi Oluştur</a>
</h3> *@
<h3 class="mb-4 d-flex justify-content-between align-items-center">
    <span>Ürün Yükleme Talepleri</span>
    <div class="btn-group">
        <a class="btn btn-primary" asp-area="Admin" asp-controller="MalYuklemeTalepForm" asp-action="CreateMalYuklemeTalepForm">
            <i class="bi bi-plus-circle"></i> Ürün Talebi Oluştur
        </a>
        <a class="btn btn-success" asp-area="Admin" asp-controller="MalYuklemeTalepForm" asp-action="ExportToExcel">
            <i class="bi bi-file-earmark-excel"></i> Excel İndir
        </a>
    </div>
</h3>


@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (Model == null || !Model.Any())
{
    <div class="alert alert-warning text-center">Gösterilecek ürün yükleme talebi bulunamadı.</div>
}
else
{
    <!-- MASAÜSTÜ TABLOSU -->
    <div class="table-responsive d-none d-md-block">
        <table class="table table-bordered table-hover text-nowrap align-middle searchable-table">
            <thead class="table-dark">
                <tr>
                    <th></th>
                    <th>Kullanıcı</th>
                    <th>Kanal</th>
                    <th>Nokta</th>
                    <th>Tarih</th>
                    <th>Brüt(₺)</th>
                    <th>Net(₺)</th>
                    <th>Kg</th>
                    <th>Maliyet(%)</th>
                    <th>Durum</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int startIndex = ((currentPage - 1) * pageSize) + 1;
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@(startIndex++)</td>
                        <td>@item.AppUser?.FirstName @item.AppUser?.LastName</td>
                        <td>@item.Kanal?.KanalName</td>
                        <td>@item.Point?.PointName</td>
                        <td>@item.CreateDate.ToShortDateString()</td>
                        <td>@item.BrutTotal?.ToString("N2")</td>
                        <td>@item.Total?.ToString("N2")</td>
                        <td>@item.ToplamAgirlikKg?.ToString("N2")</td>
                        <td>@(item.Maliyet?.ToString("N2") + " %")</td>
                        <td>
                            <span class="badge
                                @(item.TalepDurumu == TalepDurumu.Onaylandi ? "bg-success" :
                                  item.TalepDurumu == TalepDurumu.Reddedildi ? "bg-danger" :
                                  "bg-warning text-dark")">
                                @item.TalepDurumu
                            </span>
                        </td>
                        <td class="d-flex gap-1 justify-content-center flex-wrap">
                            <a asp-action="Detail" asp-route-id="@item.MalYuklemeTalepFormId" class="btn btn-sm btn-outline-primary">Detay</a>
                            @if (User.IsInRole("Admin") || (User.IsInRole("BolgeMuduru") && item.TalepDurumu == TalepDurumu.Bekliyor))
                            {
                                <form method="post" asp-action="Delete" asp-route-id="@item.MalYuklemeTalepFormId" onsubmit="return confirm('Silmek istediğinize emin misiniz?')" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-danger">Sil</button>
                                </form>
                            }
                            @if (User.IsInRole("Admin") && item.TalepDurumu == TalepDurumu.Bekliyor)
                            {
                                <form method="post" asp-action="Approve" asp-route-id="@item.MalYuklemeTalepFormId" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-success">Onayla</button>
                                </form>
                                <form method="post" asp-action="Reject" asp-route-id="@item.MalYuklemeTalepFormId" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-warning">Reddet</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- MOBİL KARTLAR -->
    <div class="d-md-none searchable-list">
        @foreach (var item in Model)
        {
            <div class="mal-yukleme-card mb-3 p-2 rounded-3 shadow-sm">
                <div class="talep-header mb-2 d-flex justify-content-between align-items-center">
                    <span class="fw-bold" style="color:#225a99;">
                        @item.AppUser?.FirstName @item.AppUser?.LastName
                    </span>
                    <span class="badge
                    @(item.TalepDurumu == TalepDurumu.Onaylandi ? "bg-success" :
                    item.TalepDurumu == TalepDurumu.Reddedildi ? "bg-danger" :
                    "bg-warning text-dark")">
                        @item.TalepDurumu
                    </span>
                </div>
                <div class="mal-yukleme-kart-icerik" style="font-size:0.98rem;">
                    <div>
                        <span class="small-label">Kanal:</span>
                        <span class="fw-semibold">@item.Kanal?.KanalName</span>
                    </div>
                    <div>
                        <span class="small-label">Nokta:</span>
                        <span class="fw-semibold">@item.Point?.PointName</span>
                    </div>
                    <div>
                        <span class="small-label">Tarih:</span>
                        <span>@item.CreateDate.ToShortDateString()</span>
                    </div>
                    <div>
                        <span class="small-label">Brüt:</span>
                        <span class="fw-semibold">@item.BrutTotal?.ToString("C2")</span>
                        <span class="small-label ms-2">Net:</span>
                        <span class="fw-semibold">@item.Total?.ToString("C2")</span>
                    </div>
                    <div>
                        <span class="small-label">Tonaj:</span>
                        <span class="fw-semibold">@item.ToplamAgirlikKg?.ToString("N2") kg</span>
                    </div>
                    <div>
                        <span class="small-label">Maliyet:</span>
                        <span class="fw-semibold">@(item.Maliyet?.ToString("N2")) %</span>
                    </div>
                </div>
                <div class="talep-actions d-flex flex-wrap gap-2 mt-2">
                    <a asp-action="Detail" asp-route-id="@item.MalYuklemeTalepFormId"
                       class="btn btn-outline-primary btn-sm flex-fill">
                        <i class="bi bi-info-circle me-1"></i>Detay
                    </a>
                    @if (User.IsInRole("Admin") || (User.IsInRole("BolgeMuduru") && item.TalepDurumu == TalepDurumu.Bekliyor))
                    {
                        <form method="post" asp-action="Delete" asp-route-id="@item.MalYuklemeTalepFormId"
                              onsubmit="return confirm('Silmek istediğinize emin misiniz?')" style="display:inline;">
                            <button type="submit" class="btn btn-danger btn-sm flex-fill">
                                <i class="bi bi-trash me-1"></i>Sil
                            </button>
                        </form>
                    }
                    @if (User.IsInRole("Admin") && item.TalepDurumu == TalepDurumu.Bekliyor)
                    {
                        <form method="post" asp-action="Approve" asp-route-id="@item.MalYuklemeTalepFormId" style="display:inline;">
                            <button type="submit" class="btn btn-success btn-sm flex-fill">
                                <i class="bi bi-check-circle me-1"></i>Onayla</button>
                        </form>
                        <form method="post" asp-action="Reject" asp-route-id="@item.MalYuklemeTalepFormId" style="display:inline;">
                            <button type="submit" class="btn btn-warning btn-sm flex-fill">
                                <i class="bi bi-x-circle me-1"></i>Reddet</button>
                        </form>
                    }
                </div>
            </div>
        }
    </div>


    @if (totalPages > 1)
    {
        <nav class="mt-4 d-flex justify-content-center">
            <ul class="pagination pagination-sm">
                @* ... Sayfalandırma kodun buraya ... *@
            </ul>
        </nav>
        <p class="text-center mt-3">Toplam Kayıt: <b>@totalCount</b> | Sayfa @currentPage / @totalPages</p>
    }
}

