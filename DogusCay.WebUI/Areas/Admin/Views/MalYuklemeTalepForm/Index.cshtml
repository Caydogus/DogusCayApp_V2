@model List<ResultMalYuklemeTalepFormDto>
@{
    ViewData["Title"] = "";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var jwt = Context.Session.GetString("JwtToken");
}
<input type="hidden" id="jwtToken" value="@jwt" />

<h3 class="mb-4 d-flex justify-content-between align-items-center">
    <a class="btn btn-success" asp-area="Admin" asp-controller="MalYuklemeTalepForm" asp-action="CreateMalYuklemeTalepForm">+ Yeni Talep Oluştur</a>
</h3>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (!Model.Any())
{
    <div class="alert alert-warning">Gösterilecek mal yükleme talebi bulunamadı.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-bordered table-hover text-nowrap">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Kullanıcı</th>
                    <th>Kanal</th>
                    <th>Point</th>
                    <th>Tarih</th>
                    <th>Net (₺)</th>
                    <th>Brüt (₺)</th>
                    <th>Kg</th>
                    <th>Maliyet (%)</th>
                    <th>Durum</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.MalYuklemeTalepFormId</td>
                        <td>@item.AppUser?.FirstName</td>
                        <td>@item.Kanal?.KanalName</td>
                        <td>@item.Point?.PointName</td>
                        <td>@item.CreateDate.ToShortDateString()</td>
                        <td>@item.Total?.ToString("N2")</td>
                        <td>@item.BrutTotal?.ToString("N2")</td>
                        <td>@item.ToplamAgirlikKg?.ToString("N2")</td>
                        <td>@item.Maliyet?.ToString("N2")</td>
                        <td>
                            <span class="badge
                                @(item.TalepDurumu == TalepDurumu.Onaylandi ? "bg-success" :
                                  item.TalepDurumu == TalepDurumu.Reddedildi ? "bg-danger" :
                                  "bg-warning text-dark")">
                                @item.TalepDurumu
                            </span>
                        </td>

                        <td class="d-flex gap-1">
                            <a asp-action="Detail" asp-route-id="@item.MalYuklemeTalepFormId" class="btn btn-sm btn-outline-primary">Detay</a>

                            @if (User.IsInRole("Admin") || (User.IsInRole("BolgeMuduru") && item.TalepDurumu == TalepDurumu.Bekliyor))
                            {
                                <form method="post" asp-action="Delete" asp-route-id="@item.MalYuklemeTalepFormId" onsubmit="return confirm('Silmek istediğinize emin misiniz?')" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-danger">Sil</button>
                                </form>
                            }

                            @if (User.IsInRole("Admin") && item.TalepDurumu == TalepDurumu.Bekliyor)
                            {
                                <form method="post" asp-action="Approve" asp-route-id="@item.MalYuklemeTalepFormId" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-success">Onayla</button>
                                </form>
                                <form method="post" asp-action="Reject" asp-route-id="@item.MalYuklemeTalepFormId" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-warning">Reddet</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <nav class="mt-4 d-flex justify-content-center">
            <ul class="pagination pagination-sm">
                @if (ViewBag.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)" asp-route-pageSize="@ViewBag.PageSize">« Önceki</a>
                    </li>
                }

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-pageSize="@ViewBag.PageSize">@i</a>
                    </li>
                }

                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage + 1)" asp-route-pageSize="@ViewBag.PageSize">Sonraki »</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
