
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Grafik Raporları";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/charts.css" asp-append-version="true" />
</head>
<body>
    <div class="chart-container">
        <div class="chart-box">
            <h5>Bölge Müdürü İnsert Sayısı</h5>
            <canvas id="bolgeChart"></canvas>
        </div>
        <div class="chart-box">
            <h5>İnsert Ürün Dağılımı</h5>
            <canvas id="urunAdetPieChart"></canvas>
        </div>
    </div>

    <div id="otherProductsModal" class="modal">
        <div class="modal-content">
            <span class="close-button">&times;</span>
            <h5>Diğer Ürün Detayları</h5>
            <ul id="otherProductsList">
            </ul>
        </div>
    </div>

    <script src="~/js/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>
    <script>
        // API'dan gelen veriler
        var bolgeLabels = @Html.Raw(ViewBag.BolgeLabels ?? "[]");
        var bolgeValues = @Html.Raw(ViewBag.BolgeValues ?? "[]");

        // 2. Pie: Ürün başına toplam adet (Quantity)
        var urunAdetLabelsRaw = @Html.Raw(ViewBag.UrunAdetLabels ?? "[]");
        var urunAdetValuesRaw = @Html.Raw(ViewBag.UrunAdetValues ?? "[]");

        // Orijinal ürün verilerini saklayalım, Diğer'e tıklandığında kullanmak için
        var originalUrunVerileri = [];
        for (var i = 0; i < urunAdetLabelsRaw.length; i++) {
            originalUrunVerileri.push({
                label: urunAdetLabelsRaw[i],
                value: urunAdetValuesRaw[i]
            });
        }

        // Değerlere göre azalan sırada sırala
        originalUrunVerileri.sort((a, b) => b.value - a.value);

        // En yüksek 5 ürünü ve geri kalanları 'Diğer' olarak grupla
        var urunAdetLabels = [];
        var urunAdetValues = [];
        var digerAdet = 0;
        var limit = 5; // Gösterilecek maksimum ürün sayısı

        // 'Diğer' kategorisine girecek ürünleri bu dizide tutalım
        var otherProductsDetails = [];

        for (var i = 0; i < originalUrunVerileri.length; i++) {
            if (i < limit) {
                urunAdetLabels.push(originalUrunVerileri[i].label);
                urunAdetValues.push(originalUrunVerileri[i].value);
            } else {
                digerAdet += originalUrunVerileri[i].value;
                otherProductsDetails.push(originalUrunVerileri[i]); // Diğer ürünleri kaydet
            }
        }

        // Eğer 'Diğer' grubunda veri varsa ekle
        if (originalUrunVerileri.length > limit) {
            urunAdetLabels.push('Diğer');
            urunAdetValues.push(digerAdet);
        }

        var totalAdet = urunAdetValues.reduce((a, b) => a + b, 0);


        // BAR CHART (Bölge Müdürü Talep Sayısı) - Bu kısımda değişiklik yok
        if (bolgeLabels.length > 0 && bolgeValues.length > 0) {
            new Chart(document.getElementById('bolgeChart').getContext('2d'), {
                type: 'bar',
                data: {
                    labels: bolgeLabels,
                    datasets: [{
                        label: 'Talep Sayısı',
                        data: bolgeValues,
                        backgroundColor: 'rgba(54, 162, 235, 0.6)',
                        borderColor: 'rgba(54, 162, 235, 1)',
                        borderWidth: 2,
                        datalabels: {
                            anchor: 'center',
                            align: 'center',
                            formatter: function(value, context) {
                                var label = context.chart.data.labels[context.dataIndex];
                                return label + ": " + value;
                            },
                            font: { weight: 'bold', size: 14 },
                            color: '#000'
                        }
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    plugins: {
                        legend: { display: false },
                        datalabels: {
                            color: '#000',
                            font: { weight: 'bold', size: 14 }
                        }
                    },
                    scales: {
                        x: {
                            beginAtZero: true
                        },
                        y: {
                            ticks: {
                                display: false
                            }
                        }
                    }
                },
                plugins: [ChartDataLabels]
            });
        }


        // PIE CHART 2: Ürünlerin Toplam Adet Dağılımı (Tıklama Olayı Eklendi)
        if (urunAdetLabels.length > 0 && urunAdetValues.length > 0) {
            var urunPieChart = new Chart(document.getElementById('urunAdetPieChart').getContext('2d'), {
                type: 'pie',
                data: {
                    labels: urunAdetLabels,
                    datasets: [{
                        data: urunAdetValues,
                        backgroundColor: [
                            'rgba(255, 99, 132, 0.6)', // 1
                            'rgba(54, 162, 235, 0.6)', // 2
                            'rgba(255, 206, 86, 0.6)', // 3
                            'rgba(75, 192, 192, 0.6)', // 4
                            'rgba(153, 102, 255, 0.6)',// 5
                            'rgba(201, 203, 207, 0.6)'  // 'Diğer' için gri tonu (6. renk)
                        ],
                        datalabels: {
                            color: '#222',
                            font: { weight: 'bold', size: 13 },
                            formatter: function(value, context) {
                                var percent = totalAdet > 0 ? (value * 100 / totalAdet).toFixed(1) : 0;
                                return value + " (%" + percent + ")";
                            }
                        }
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { position: 'bottom' },
                        datalabels: { display: true }
                    },
                    // Yeni: Tıklama olayını ekle
                    onClick: function(event, elements) {
                        if (elements.length > 0) {
                            var clickedElementIndex = elements[0].index;
                            var clickedLabel = this.data.labels[clickedElementIndex];

                            if (clickedLabel === 'Diğer' && otherProductsDetails.length > 0) {
                                showOtherProductsModal(otherProductsDetails, totalAdet);
                            }
                        }
                    }
                },
                plugins: [ChartDataLabels]
            });
        }

        // Modal ile ilgili JavaScript kodları
        var modal = document.getElementById("otherProductsModal");
        var span = document.getElementsByClassName("close-button")[0];
        var otherProductsList = document.getElementById("otherProductsList");

        function showOtherProductsModal(products, totalSum) {
            otherProductsList.innerHTML = ''; // Listeyi temizle
            products.forEach(function(product) {
                var listItem = document.createElement('li');
                var percent = totalSum > 0 ? (product.value * 100 / totalSum).toFixed(1) : 0;
                listItem.textContent = `${product.label}: ${product.value} adet (%${percent})`;
                otherProductsList.appendChild(listItem);
            });
            modal.style.display = "block"; // Modalı göster
        }

        // Kapatma butonuna basınca modalı gizle
        span.onclick = function() {
            modal.style.display = "none";
        }

        // Modal dışına tıklayınca modalı gizle
        window.onclick = function(event) {
            if (event.target == modal) {
                modal.style.display = "none";
            }
        }
    </script>
</body>
</html>

